<component name = "GridItem" extends = "Group" >
 
  <interface > 
    <field id = "itemContent" type = "node" onChange = "showcontent"/>
    <field id = "focusPercent" type = "float" onChange = "showfocus" alwaysNotify = "true"/>
    <field id = "gridHasFocus" type = "boolean" onChange = "showfocus" alwaysNotify = "true"/>
  </interface>
 
  <script type = "text/brightscript" uri = "GridItem.brs" />

  <children >
    
    <!-- <Poster 
      id = "itemPoster" 
      translation = "[ 0, 0 ]" 
      width = "320" 
      height = "180" 
       >

    </Poster> -->

    <Rectangle id = "itemBackground" width = "100" height = "60"/> 

    <Label 
      id = "itemLabel" 
      translation = "[0,0]" 
      height = "60"
      width = "100"
      color = "0x000000FF"
      horizAlign = "center"
      vertAlign = "center" 
      opacity = "1.0"/>

  </children>

</component>